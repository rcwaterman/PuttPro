<?xml version="1.0" encoding="utf-8"?>
<!--
    Allows Android (API 24+) to trust user-installed CA certificates.
    Required for the mkcert CA cert installed via the server's QR code.

    APPLY THIS AFTER 'npx cap add android':
      1. Copy this file to:
         android/app/src/main/res/xml/network_security_config.xml

      2. In android/app/src/main/AndroidManifest.xml, add to <application>:
         android:networkSecurityConfig="@xml/network_security_config"
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="user"/>
        </trust-anchors>
    </base-config>
</network-security-config>
